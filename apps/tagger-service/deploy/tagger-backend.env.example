# Copy to a machine-local env file and fill values there. Do not commit real paths or secrets.
TAGGER_ROLE=backend
TAGGER_HOST=0.0.0.0
TAGGER_PORT=8000
UV_PROJECT_ENVIRONMENT=<LOCAL_SHARED_VENV_DIR>
# Required for onnxruntime-gpu when cuDNN is provided by the backend-gpu Python extra.
LD_LIBRARY_PATH=<LOCAL_SHARED_VENV_DIR>/lib/python3.11/site-packages/nvidia/cudnn/lib:<LOCAL_SHARED_VENV_DIR>/lib/python3.11/site-packages/nvidia/cublas/lib:/usr/local/cuda-12.4/targets/x86_64-linux/lib
TAGGER_MAX_BATCH_PATHS=64
TAGGER_WD14_MODEL_DIR=<LOCAL_WD14_MODEL_DIR>
TAGGER_EVA02_MODEL_DIR=<LOCAL_EVA02_MODEL_DIR>
HF_HUB_OFFLINE=1
TAGGER_API_TOKENS=<BACKEND_BEARER_TOKEN>

MINIO_ENDPOINT=<MINIO_ENDPOINT>
MINIO_PORT=9000
MINIO_ACCESS_KEY=<MINIO_ACCESS_KEY>
MINIO_SECRET_KEY=<MINIO_SECRET_KEY>
MINIO_BUCKET=pixiv
MINIO_SECURE=false
