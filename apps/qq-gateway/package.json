{
    "name": "qq-gateway",
    "version": "1.0.0",
    "description": "QQ 官方机器人网关：被动收发文本，归一化为 custom 协议对接 channel-server",
    "type": "module",
    "scripts": {
        "start": "bun src/index.ts",
        "build": "bun build src/index.ts --compile --outfile=server",
        "typecheck": "tsc --noEmit",
        "test": "bun test",
        "test:watch": "bun test --watch"
    },
    "author": "Chiwei",
    "license": "MIT",
    "devDependencies": {
        "@types/bun": "latest",
        "typescript": "^5.6.3"
    },
    "dependencies": {
        "@inner/shared": "workspace:*",
        "async-mutex": "^0.5.0",
        "hono": "^4.7.0",
        "ioredis": "^5.3.2"
    }
}
